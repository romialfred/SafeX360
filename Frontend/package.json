{
  "name": "hs-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "npm run dev",
    "build": "tsc -b && vite build",
    "performance:budget": "node scripts/check-performance-budgets.mjs",
    "build:mobile": "tsc -b && vite build --mode mobile",
    "lint": "eslint .",
    "lint:baseline": "node scripts/check-eslint-baseline.mjs",
    "lint:baseline:update": "node scripts/check-eslint-baseline.mjs --update",
    "design:baseline": "node scripts/check-design-debt-baseline.mjs",
    "design:baseline:update": "node scripts/check-design-debt-baseline.mjs --update",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:security": "npm audit --audit-level=high",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:smoke": "npm run build && playwright test e2e/smoke",
    "test:e2e:install": "playwright install chromium",
    "android:harden": "node scripts/harden-android-backup.mjs",
    "cap:sync": "npm run build && npx cap sync && npm run android:harden",
    "cap:android": "npm run build && npx cap sync android && npm run android:harden && npx cap open android",
    "cap:android:run": "npm run build && npx cap sync android && npm run android:harden && npx cap run android",
    "android:build:debug": "npm run build && npx cap sync android && npm run android:harden && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run build && npx cap sync android && npm run android:harden && cd android && ./gradlew assembleRelease",
    "android:build:release:signed": "npm run build && npx cap sync android && npm run android:harden && cd android && ./gradlew assembleRelease -PkeystoreProperties=key.properties",
    "android:build:bundle": "npm run build && npx cap sync android && npm run android:harden && cd android && ./gradlew bundleRelease",
    "android:clean": "cd android && ./gradlew clean"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/geolocation": "^6.1.0",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/network": "^6.0.3",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/react": "^6.1.17",
    "@iconify-icon/react": "^2.3.0",
    "@mantine/carousel": "^7.17.2",
    "@mantine/charts": "^7.17.2",
    "@mantine/core": "^7.17.2",
    "@mantine/dates": "^7.17.2",
    "@mantine/dropzone": "^7.17.2",
    "@mantine/form": "^7.17.2",
    "@mantine/hooks": "^7.17.2",
    "@mantine/modals": "^7.17.2",
    "@mantine/notifications": "^7.17.2",
    "@mantine/nprogress": "^7.17.2",
    "@mantine/tiptap": "^7.17.2",
    "@react-map/africa": "^1.0.13",
    "@reduxjs/toolkit": "^2.6.1",
    "@stomp/stompjs": "^7.3.0",
    "@tabler/icons-react": "^3.31.0",
    "@tailwindcss/vite": "^4.0.14",
    "@tiptap/extension-highlight": "^2.11.7",
    "@tiptap/extension-link": "^2.11.7",
    "@tiptap/extension-underline": "^2.11.7",
    "@tiptap/pm": "^2.11.7",
    "@tiptap/react": "^2.11.7",
    "@tiptap/starter-kit": "^2.11.7",
    "@types/dompurify": "^3.0.5",
    "aos": "^2.3.4",
    "axios": "^1.8.4",
    "dayjs": "^1.11.13",
    "dompurify": "^3.4.8",
    "embla-carousel-react": "^8.6.0",
    "html5-qrcode": "^2.3.8",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb": "^8.0.3",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.3.0",
    "recharts": "^2.15.1",
    "remark-gfm": "^4.0.1",
    "sockjs-client": "^1.6.1",
    "tailwindcss": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.8",
    "workbox-window": "^7.3.0"
  },
  "overrides": {
    "@capacitor/cli": {
      "tar": "7.5.19"
    }
  }
}
