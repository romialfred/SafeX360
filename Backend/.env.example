# ============================================================================
# SafeX360 — Backend .env (exemple)
# Copiez en .env et remplissez les valeurs réelles
# ============================================================================

# Base de données MySQL
DB_URL='jdbc:mysql://localhost:3306/safex?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true'
DB_USERNAME=root
DB_PASSWORD='changeme'

# JWT — générer avec : openssl rand -hex 64
JWT_SECRET='changeme-generate-with-openssl-rand-hex-64'

# Identites workload: une cle differente par emetteur/audience (openssl rand -hex 32).
# Laisser vide fait echouer le demarrage en production. Dans le secret manager,
# ne fournir a chaque service que ses cles entrantes/sortantes strictement necessaires.
SAFEX_GATEWAY_HNS_TOKEN_KEY=
SAFEX_GATEWAY_HRMS_TOKEN_KEY=
SAFEX_HNS_HRMS_TOKEN_KEY=
SAFEX_HRMS_HNS_TOKEN_KEY=

# Chiffrement AES-GCM des secrets TOTP; cle distincte, geree et rotee hors Git.
MFA_ENCRYPTION_KEY=

# Annuaire synthétique HRMS — uniquement avec SPRING_PROFILES_ACTIVE=dev|test
# Générer une valeur locale distincte ; ne jamais la réutiliser en production.
SAFEX_DEMO_DIRECTORY_PASSWORD='<generate-local-only>'

# LOT 41 P1 — durée de vie JWT en heures (défaut recommandé : 8)
JWT_EXPIRATION_HOURS=8

# Mail SMTP (no-reply)
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD='changeme'
MAIL_FROM=no-reply@example.com

# Eureka registry (laisser par défaut en local)
# EUREKA_SERVER_URL=http://localhost:8761/eureka/
